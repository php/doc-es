<refentry xml:id="function.ssh2-sftp-readlink" xmlns="http://docbook.org/ns/docbook">
 <refnamediv>
  <refname>ssh2_sftp_readlink</refname>
  <refpurpose>Devuelve el destino de un enlace simbólico</refpurpose>
 </refnamediv>

 <refsect1 role="description">
  &reftitle.description;
  <methodsynopsis>
   <type class="union"><type>string</type><type>false</type></type><methodname>ssh2_sftp_readlink</methodname>
   <methodparam><type>resource</type><parameter>sftp</parameter></methodparam>
   <methodparam><type>string</type><parameter>link</parameter></methodparam>
  </methodsynopsis>
  <simpara>
   Devuelve el destino de un enlace simbólico.
  </simpara>
 </refsect1>

 <refsect1 role="parameters">
  &reftitle.parameters;
  <variablelist>
   <varlistentry>
    <term><parameter>sftp</parameter></term>
    <listitem>
     <simpara>
      Un recurso SSH2 SFTP, abierto por la función <function>ssh2_sftp</function>.
     </simpara>
    </listitem>
   </varlistentry>
   <varlistentry>
    <term><parameter>link</parameter></term>
    <listitem>
     <simpara>
      Ruta hacia el enlace simbólico.
     </simpara>
    </listitem>
   </varlistentry>
  </variablelist>
 </refsect1>

 <refsect1 role="returnvalues">
  &reftitle.returnvalues;
  <simpara>
   Devuelve el destino del enlace simbólico <parameter>link</parameter>&return.falseforfailure;.
  </simpara>
 </refsect1>

 <refsect1 role="examples">
  &reftitle.examples;
  <example>
   <title>Lectura de un enlace simbólico</title>
   <programlisting role="php">
<![CDATA[
<?php
$connection = ssh2_connect('shell.example.com', 22);
ssh2_auth_password($connection, 'username', 'password');
$sftp = ssh2_sftp($connection);

$target = ssh2_sftp_readlink($sftp, '/tmp/mysql.sock');
/* $target es ahora (e.g.): '/var/run/mysql.sock' */
?>
]]>
   </programlisting>
  </example>
 </refsect1>

 <refsect1 role="seealso">
  &reftitle.seealso;
  <simplelist>
   <member><function>readlink</function></member>
   <member><function>ssh2_sftp_symlink</function></member>
  </simplelist>
 </refsect1>

</refentry>
