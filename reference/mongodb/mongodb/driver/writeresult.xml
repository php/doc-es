 <partintro>

<!-- {{{ MongoDB\Driver\WriteResult intro -->
  <section xml:id="mongodb-driver-writeresult.intro">
   &reftitle.intro;
   <para>
    La clase <classname>MongoDB\Driver\WriteResult</classname> contiene las
    informaciones sobre una ejecución <classname>MongoDB\Driver\BulkWrite</classname>
    y puede ser retornado por
 <methodname>MongoDB\Driver\Manager::executeBulkWrite</methodname>.

   </para>
  </section>
<!-- }}} -->

