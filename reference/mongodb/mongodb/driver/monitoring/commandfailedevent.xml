<!-- {{{ MongoDB\Driver\Monitoring\CommandFailedEvent intro -->
  <section xml:id="mongodb-driver-monitoring-commandfailedevent.intro">
   &reftitle.intro;
   <para>
    La clase <classname>MongoDB\Driver\Monitoring\CommandFailedEvent</classname>
    contiene la información sobre una comando que ha fallado.
   </para>
  </section>
<!-- }}} -->

